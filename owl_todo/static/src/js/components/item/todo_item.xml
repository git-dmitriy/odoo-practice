<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="owl_todo.TodoItem">
        <div
                class="o_owl_todo_row"
                draggable="true"
                t-att-class="{
                    'o_owl_todo_row_done': props.task.is_done,
                    'o_owl_todo_row_dragging': props.isDragging,
                    'o_owl_todo_row_drag_over': props.isDragOver
                }"
                t-on-dragstart="(ev) => props.onDragStart(props.task, ev)"
                t-on-dragover="(ev) => props.onDragOver(props.task, ev)"
                t-on-drop="(ev) => props.onDrop(props.task, ev)"
                t-on-dragend="props.onDragEnd"
        >
            <button
                    type="button"
                    class="o_owl_todo_row_check"
                    role="checkbox"
                    t-att-aria-checked="props.task.is_done ? 'true' : 'false'"
                    t-att-aria-label="props.task.is_done ? 'Mark as not done' : 'Mark as done'"
                    t-att-title="props.task.is_done ? 'Mark as active' : 'Mark as done'"
                    t-on-click="() => props.onToggleDone(props.task)"
            >
                <span class="o_owl_todo_row_check_mark" aria-hidden="true"/>
            </button>
            <div class="o_owl_todo_row_body">
                <div class="o_owl_todo_row_title_row">
                    <span class="o_owl_todo_row_title" t-esc="props.task.name"/>
                </div>
                <div class="o_owl_todo_row_desc" t-if="props.task.description" t-esc="props.task.description"/>
                <div class="o_owl_todo_row_actions">
                    <button type="button" class="o_owl_todo_btn o_owl_todo_btn_text"
                            t-on-click="() => props.onEdit(props.task)">
                        Edit
                    </button>
                    <button type="button" class="o_owl_todo_btn o_owl_todo_btn_text o_owl_todo_btn_danger"
                            t-on-click="() => props.onDelete(props.task)">
                        Delete
                    </button>
                </div>
            </div>
        </div>
    </t>
</templates>
