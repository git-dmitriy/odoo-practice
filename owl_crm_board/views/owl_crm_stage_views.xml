<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="owl_crm_stage_tree" model="ir.ui.view">
        <field name="name">owl.crm.stage.tree</field>
        <field name="model">owl.crm.stage</field>
        <field name="arch" type="xml">
            <tree string="Stages">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="fold"/>
            </tree>
        </field>
    </record>

    <record id="owl_crm_stage_form" model="ir.ui.view">
        <field name="name">owl.crm.stage.form</field>
        <field name="model">owl.crm.stage</field>
        <field name="arch" type="xml">
            <form string="Stage">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="fold"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="owl_crm_stage_action" model="ir.actions.act_window">
        <field name="name">CRM Stages</field>
        <field name="res_model">owl.crm.stage</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
