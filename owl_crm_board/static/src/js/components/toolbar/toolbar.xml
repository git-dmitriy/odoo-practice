<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="owl_crm_board.BoardToolbar">
        <div class="o_owl_crm_toolbar">
            <input
                type="text"
                class="form-control"
                placeholder="Search by lead or customer..."
                t-att-value="filters.query"
                t-on-input="onSearchInput"
            />
            <select class="form-select" t-on-change="onPriorityChanged">
                <option value="all" t-att-selected="filters.priority === 'all'">All priorities</option>
                <option value="0" t-att-selected="filters.priority === '0'">Low</option>
                <option value="1" t-att-selected="filters.priority === '1'">Normal</option>
                <option value="2" t-att-selected="filters.priority === '2'">High</option>
                <option value="3" t-att-selected="filters.priority === '3'">Very high</option>
            </select>
            <select class="form-select" t-on-change="onSortChanged">
                <option value="priority" t-att-selected="filters.sortBy === 'priority'">Sort: priority</option>
                <option value="name" t-att-selected="filters.sortBy === 'name'">Sort: name</option>
            </select>
            <button class="btn btn-primary" t-on-click="() => props.onCreate()">+ Lead</button>
        </div>
    </t>
</templates>
