<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="theme_bootstrap_cookies_html_attrs" inherit_id="website.layout" name="Theme Cookies HTML Attributes">
        <xpath expr="//html" position="attributes">
            <attribute name="t-att-data-theme">request.httprequest.cookies.get('website_theme_mode') if request.httprequest.cookies.get('website_theme_mode') in ['light', 'dark'] else 'light'</attribute>
            <attribute name="t-att-data-bs-theme">request.httprequest.cookies.get('website_theme_mode') if request.httprequest.cookies.get('website_theme_mode') in ['light', 'dark'] else 'light'</attribute>
        </xpath>
    </template>

    <template id="theme_bootstrap_cookies_header_toggle" inherit_id="website.layout" name="Theme Cookies Toggle">
        <xpath expr="//div[@id='wrapwrap']" position="inside">
            <div class="container py-2 d-flex justify-content-end align-items-center theme-toggle-navbar theme-toggle-navbar-cookies">
                <button
                    type="button"
                    id="theme_mode_toggle_cookies"
                    class="btn btn-link nav-link p-2"
                    aria-label="Switch to dark theme"
                    title="Switch theme"
                >
                    <span class="theme-icon theme-icon-sun" aria-hidden="true">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="5"></circle>
                            <line x1="12" y1="1" x2="12" y2="3"></line>
                            <line x1="12" y1="21" x2="12" y2="23"></line>
                            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                            <line x1="1" y1="12" x2="3" y2="12"></line>
                            <line x1="21" y1="12" x2="23" y2="12"></line>
                            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
                        </svg>
                    </span>
                    <span class="theme-icon theme-icon-moon d-none" aria-hidden="true">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 12.79A9 9 0 1 1 11.21 3c0.03 0 0.06 0 0.09 0A7 7 0 1 0 21 12.79z"></path>
                        </svg>
                    </span>
                </button>
            </div>
        </xpath>
    </template>

</odoo>
